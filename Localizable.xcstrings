    "Adjust sensitivity for voice detection. Lower values detect quieter speech." : {
      "comment" : "A description of the slider that adjusts the sensitivity of voice detection.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Empfindlichkeit für Spracherkennung anpassen. Niedrigere Werte erkennen leisere Sprache."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust sensitivity for voice detection. Lower values detect quieter speech."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ajusta la sensibilidad para la detección de voz. Los valores más bajos detectan voces más suaves."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ajustez la sensibilité de la détection vocale. Des valeurs plus basses détectent des voix plus discrètes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Regola la sensibilità per il rilevamento vocale. Valori più bassi rilevano voci più basse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dostosuj czułość wykrywania głosu. Niższe wartości wykrywają cichszą mowę."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ajuste a sensibilidade para detecção de voz. Valores menores detectam vozes mais baixas."
          }
        }
      }
    },
